{
  "name": "mjscoreboard",
  "private": true,
  "version": "1.7.2",
  "description": "A real-time scoring app for competitive Mahjong (Chinese Official rules), with BLE scoreboard support.",
  "author": "Rui Li",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarsNavi/MjscoreBoard.git"
  },
  "homepage": "https://github.com/MarsNavi/MjscoreBoard",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "android:build": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "ios:build": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:release-check": "npm run ios:build && xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Release -destination 'generic/platform=iOS' CODE_SIGNING_ALLOWED=NO build",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.0",
    "@capacitor/android": "^8.0.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/filesystem": "^8.1.0",
    "@capacitor/ios": "^8.0.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-bluetooth-low-energy": "^8.1.1",
    "cordova-plugin-ble-peripheral": "^1.0.0",
    "dexie": "^4.2.1",
    "i18next": "^26.3.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "tar": "^7.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.60.0",
    "postcss": "^8.4.35",
    "postinstall-postinstall": "^2.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
